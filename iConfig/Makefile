iConnectivity\ iConfig.app/Contents/PkgInfo: 
	@test -d iConnectivity\ iConfig.app/Contents || mkdir -p iConnectivity\ iConfig.app/Contents
	@$(DEL_FILE) iConnectivity\ iConfig.app/Contents/PkgInfo
	@echo "APPL????" > iConnectivity\ iConfig.app/Contents/PkgInfo
iConnectivity\ iConfig.app/Contents/Info.plist: 
	@test -d iConnectivity\ iConfig.app/Contents || mkdir -p iConnectivity\ iConfig.app/Contents
	@$(DEL_FILE) iConnectivity\ iConfig.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - /opt/homebrew/share/qt/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.intelliriffer.iConnectivity-iConfig,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.intelliriffer.iConnectivity-iConfig,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},10.15,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,Icon.icns,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},Icon.icns,g" -e "s,@EXECUTABLE@,iConnectivity iConfig,g" -e "s,@LIBRARY@,iConnectivity iConfig,g" -e "s,\$${EXECUTABLE_NAME},iConnectivity iConfig,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >iConnectivity\ iConfig.app/Contents/Info.plist
